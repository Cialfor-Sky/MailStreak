PORT=8000
APP_ENV=development
JWT_SECRET=replace_with_a_long_random_secret
OPENAI_API_KEY=replace_with_openai_api_key
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
DB_PATH=./data/mailstreak.db
MODEL_PATH=./artifacts/ensemble_model.joblib
TRAIN_ON_STARTUP=false
FRONTEND_DIST=
DATA_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365
GDPR_HARD_DELETE_DELAY_DAYS=7
RETENTION_CLEANUP_INTERVAL_MINUTES=60
REDIS_URL=redis://localhost:6379/0
WEBHOOK_MAX_RETRIES=5
ENFORCE_HTTPS=false
DEFAULT_ORG_ID=org-default
DEFAULT_ORG_NAME=Default Organization
PRIVACY_CONTACT_EMAIL=privacy@mailstreak.local
TERMS_GOVERNING_LAW=Governing law to be defined per organization
HYBRID_SUPERVISED_WEIGHT=0.5
HYBRID_ANOMALY_WEIGHT=0.3
HYBRID_HEURISTIC_WEIGHT=0.2
DEFAULT_ANOMALY_THRESHOLD=0.7
ANOMALY_MODELS_DIR=./artifacts/anomaly
DRIFT_THRESHOLD=0.25

# Staging / production guidance:
# APP_ENV=staging or APP_ENV=production
# ENFORCE_HTTPS=true
# CORS_ORIGIN should contain only trusted origins
# JWT_SECRET must be managed via secret manager

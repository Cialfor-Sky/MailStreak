# Shared deployment examples

# Backend profile
APP_ENV=development
PORT=8000
JWT_SECRET=replace_with_secret
OPENAI_API_KEY=
DB_PATH=./backend_py/data/mailstreak.db
REDIS_URL=redis://localhost:6379/0
ENFORCE_HTTPS=false

# Compliance
DATA_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365
GDPR_HARD_DELETE_DELAY_DAYS=7
HYBRID_SUPERVISED_WEIGHT=0.5
HYBRID_ANOMALY_WEIGHT=0.3
HYBRID_HEURISTIC_WEIGHT=0.2
DEFAULT_ANOMALY_THRESHOLD=0.7
ANOMALY_MODELS_DIR=./backend_py/artifacts/anomaly
DRIFT_THRESHOLD=0.25

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
